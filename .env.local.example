# Home `/`: por defeito visitantes vão direto a /painel-novos-negocios (sem botões Entrar/Cadastrar).
# Para voltar a mostrar a landing com login na raiz:
# NEXT_PUBLIC_SHOW_HOME_LOGIN=true
#
# App aberta sem login (visitante cai no painel; rotas que exigem utilizador redirecionam ao painel).
# Por defeito: PÚBLICO. Para exigir login em todo o site (exc. /admin que continua protegido):
# NEXT_PUBLIC_APP_PUBLIC=false
#
# Modo Rede + Novos Negócios: por defeito é PÚBLICO (sem login). Para exigir login nestas rotas:
# NEXT_PUBLIC_PUBLIC_REDE_NOVOS_NEGOCIOS=false
# Obrigatório para carregar/editar dados sem sessão (server-side):
# SUPABASE_SERVICE_ROLE_KEY=...
# Opcional: UUID de um user em Auth para atribuir eventos (senão usa o 1.º admin em profiles):
# PUBLIC_LINK_ACTOR_USER_ID=

# URL pública da app (links em convites por e-mail).
# Na Vercel: opcional se enviares convites abrindo o admin no próprio site (o host do browser é usado).
# Em dev (localhost): OBRIGATÓRIO para links nos e-mails apontarem à produção:
#   NEXT_PUBLIC_APP_URL=https://teu-projeto.vercel.app
# Com domínio próprio: NEXT_PUBLIC_APP_URL=https://portal.moni.casa
# NEXT_PUBLIC_APP_URL=

# Supabase (pegue em: Supabase → Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://seu-projeto.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sua-anon-key
# Escopo de release do menu/rotas:
# full (default): todas as áreas
# limited: libera apenas Rede de Franqueados + Novos Negócios (+ perfil/autenticação)
# NEXT_PUBLIC_RELEASE_SCOPE=limited
# Necessário para o script de importação da rede de franqueados (scripts/import-rede-franqueados.mjs)
# SUPABASE_SERVICE_ROLE_KEY=service_role_secret_aqui

# Opcional: Resend (e-mails), Apify (scraping ZAP)
# RESEND_API_KEY=
# Destinatário(s) do PDF Registro de Franquia (vários separados por vírgula). Se vazio, usa email_frank de cada linha.
# REGISTRO_FRANQUIA_NOTIFY_EMAILS=equipe@moni.casa,outro@exemplo.com
# Avisos de novo cadastro pendente para admins (sem valor = não envia e-mail aos admins, só ao utilizador)
# SIGNUP_NOTIFY_ADMIN_EMAILS=

# APIFY_API_TOKEN=
# PIPEDRIVE_API_TOKEN=

# Autentique Sign (envio para assinatura; signatários no template metadados.signers ou aqui)
# AUTENTIQUE_API_KEY=
# AUTENTIQUE_SIGNERS_EMAILS=email1@exemplo.com,email2@exemplo.com
