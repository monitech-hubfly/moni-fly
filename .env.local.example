# Supabase (pegue em: Supabase → Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://seu-projeto.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sua-anon-key
# Necessário para o script de importação da rede de franqueados (scripts/import-rede-franqueados.mjs)
# SUPABASE_SERVICE_ROLE_KEY=service_role_secret_aqui

# Opcional: Resend (e-mails), Apify (scraping ZAP)
# RESEND_API_KEY=
# APIFY_API_TOKEN=
# PIPEDRIVE_API_TOKEN=

# Autentique Sign (envio para assinatura; signatários no template metadados.signers ou aqui)
# AUTENTIQUE_API_KEY=
# AUTENTIQUE_SIGNERS_EMAILS=email1@exemplo.com,email2@exemplo.com
